# Generate unique values before deployment. Do not commit a populated .env file.
POSTGRES_DB=hiro
POSTGRES_USER=hiro
POSTGRES_PASSWORD=replace-with-a-long-random-password
HIRO_DATABASE_DSN=postgresql://hiro:replace-with-a-long-random-password@127.0.0.1:51432/hiro
HIRO_SERVICE_TOKEN=replace-with-a-long-random-service-token

# Model/runtime
HIRO_MODEL_NAME=BAAI/bge-base-en
HIRO_MODEL_DEVICE=cpu
HIRO_MAX_WORKERS=4
HIRO_DATABASE_POOL_SIZE=8
HIRO_MAX_MESSAGE_BYTES=1048576
HIRO_LOG_LEVEL=INFO
HIRO_ENABLE_REFLECTION=false

# Python service listener. Override HIRO_PORT per process (50052 embed, 50053 search).
HIRO_BIND_ADDRESS=127.0.0.1
HIRO_PORT=50053
# Configure both paths to enable TLS. Leave both unset only on loopback/private networks.
# HIRO_TLS_CERTIFICATE=/run/secrets/tls.crt
# HIRO_TLS_PRIVATE_KEY=/run/secrets/tls.key

# Go clients and web server
HIRO_SEARCH_GRPC_ADDRESS=127.0.0.1:50053
HIRO_EMBED_GRPC_ADDRESS=127.0.0.1:50052
HIRO_GRPC_INSECURE=true
# HIRO_GRPC_SERVER_NAME=search.internal.example
HIRO_REQUEST_TIMEOUT=5s
HIRO_EMBED_TIMEOUT=30s
HIRO_CRAWL_REQUEST_TIMEOUT=15s
HIRO_CRAWL_MAX_BODY_BYTES=2097152
# Only enable when intentionally crawling services on a trusted private network.
HIRO_CRAWL_ALLOW_PRIVATE=false
HIRO_HTTP_ADDRESS=127.0.0.1:8973
HIRO_HTTP_READ_TIMEOUT=10s
HIRO_HTTP_WRITE_TIMEOUT=15s
HIRO_HTTP_IDLE_TIMEOUT=60s
HIRO_HTTP_BODY_LIMIT=65536
HIRO_SEARCH_RATE_LIMIT=60
HIRO_DEBUG=false
